{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio1",
  "compatibility_date": "2026-04-20",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "node_modules",
      ".git",
      ".github",
      "wrangler.jsonc",
      ".gitignore",
      "posts/**",
      "test/**",
      "README.md",   
      "*.py",
      "FileDir.txt",
      "LICENSE"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}